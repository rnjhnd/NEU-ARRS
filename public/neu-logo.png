<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 Page Not Found - New Era University</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://fonts.cdnfonts.com/css/avenir" rel="stylesheet">
    
    <link href="https://neu.edu.ph/main/assets/styles/styles.css?v=6a296618e1abf" rel="stylesheet">
    
    <style>
        /* --- 404 ERROR PAGE STYLES --- */
        .error-section {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            padding: 80px 20px;
            min-height: 65vh; /* Ensures it takes up the middle of the screen */
            background-color: #fcfcfc; /* Matches the light background in the image */
        }

        .error-image {
            max-width: 350px; /* Adjust this based on your actual illustration size */
            width: 100%;
            height: auto;
            margin-bottom: 40px;
        }

        .error-section h1 {
            font-family: 'Montserrat', sans-serif;
            font-size: 2.2rem;
            font-weight: 600;
            color: #000000;
            margin-bottom: 15px;
        }

        .error-section p {
            font-family: 'Avenir', sans-serif;
            font-size: 1.1rem;
            color: #4a4a4a;
            margin-bottom: 30px;
        }

        .btn-home {
            /* Falls back to a hardcoded dark blue if the variable isn't loaded */
            background-color: var(--primary-blue, #002f6c); 
            color: #ffffff;
            font-family: 'Montserrat', sans-serif;
            font-weight: 500;
            font-size: 0.85rem;
            text-decoration: none;
            padding: 12px 30px;
            border-radius: 4px;
            transition: background-color 0.3s ease, opacity 0.3s ease;
            text-transform: uppercase;
        }

        .btn-home:hover {
            opacity: 0.85;
        }

        /* --- RESPONSIVE --- */
        @media (max-width: 600px) {
            .error-section {
                padding: 60px 20px;
            }
            .error-section h1 {
                font-size: 1.8rem;
            }
            .error-section p {
                font-size: 0.95rem;
            }
            .error-image {
                max-width: 250px;
            }
        }
    </style>
</head>
